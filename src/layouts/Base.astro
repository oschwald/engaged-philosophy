---
import PrimaryNav from "../components/layout/PrimaryNav.astro";
import SiteFooter from "../components/layout/SiteFooter.astro";
import SiteHead from "../components/layout/SiteHead.astro";
import SiteHeader from "../components/layout/SiteHeader.astro";
import { getPrimaryMenu, getRuntimeSiteSettings } from "../lib/content";
import { getMediaUrlPrefix, rewriteInternalMediaFileUrl } from "../lib/media";
import {
	createSitePageContext,
	getSitePageCacheTags,
	type SiteContentContext,
} from "../lib/page-context";
import {
	ANONYMOUS_PAGE_CACHE_MAX_AGE_SECONDS,
	ANONYMOUS_PAGE_CACHE_SWR_SECONDS,
	SITE_TAGLINE_FALLBACK,
	SITE_TITLE_FALLBACK,
} from "../lib/site-config";
import { EmDashBodyEnd, EmDashBodyStart } from "emdash/ui";
import "../scss/style.scss";

interface Props {
	title?: string;
	description?: string;
	bodyClass?: string;
	content?: SiteContentContext;
	cacheTags?: string[];
}

const {
	title,
	description,
	bodyClass = "",
	content,
	cacheTags = [],
} = Astro.props;
const routeCacheTags = getSitePageCacheTags(content, cacheTags);
Astro.response.headers.set(
	"Cache-Control",
	"public, max-age=0, must-revalidate",
);
Astro.cache.set({
	maxAge: ANONYMOUS_PAGE_CACHE_MAX_AGE_SECONDS,
	swr: ANONYMOUS_PAGE_CACHE_SWR_SECONDS,
	...(routeCacheTags.length > 0 ? { tags: routeCacheTags } : {}),
});
const settings = await getRuntimeSiteSettings();
const siteTitle = settings?.title || SITE_TITLE_FALLBACK;
const siteDescription = settings?.tagline || SITE_TAGLINE_FALLBACK;
const menuItems = await getPrimaryMenu();
const currentPath = Astro.url.pathname;
const mediaUrlPrefix = getMediaUrlPrefix();
const logo = settings?.logo;
const logoSrc = logo?.url
	? rewriteInternalMediaFileUrl(logo.url, mediaUrlPrefix)
	: `${mediaUrlPrefix}/img/logo.png`;
const logoAlt = logo?.alt || `${siteTitle} Logo`;
const page = createSitePageContext({
	url: Astro.url,
	siteTitle,
	siteDescription,
	siteUrl: settings?.url,
	title,
	description,
	content,
});
---

<!doctype html>
<html class="no-js" lang="en-US">
	<SiteHead page={page} />
	<body class={bodyClass}>
		<EmDashBodyStart page={page} />
		<div class="container">
			<SiteHeader
				siteTitle={siteTitle}
				logoSrc={logoSrc}
				logoAlt={logoAlt}
				logoWidth={logo?.width}
				logoHeight={logo?.height}
			/>

			<PrimaryNav menuItems={menuItems} currentPath={currentPath} />

			<div id="page" class="hfeed row">
				<slot />
				<SiteFooter siteTitle={siteTitle} />
			</div>
		</div>
		<script>
			import "../js/index.js";
		</script>
		<EmDashBodyEnd page={page} />
	</body>
</html>
