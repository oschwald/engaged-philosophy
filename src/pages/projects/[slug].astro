---
import HtmlContent from "../../components/HtmlContent.astro";
import Base from "../../layouts/Base.astro";
import { getEmDashEntry } from "emdash";
import { getProjectBySlug } from "../../lib/seed";

const { slug = "" } = Astro.params;
const project = getProjectBySlug(slug);

const liveProject = project
	? null
	: await getEmDashEntry("projects", slug).then((result) => result.entry);

if (!project && !liveProject) {
	return Astro.redirect("/404");
}

if (project) {
	return Astro.redirect(`/${project.data.path}/`);
}

const liveEntry = liveProject!;
const title =
	typeof liveEntry.data.title === "string" ? liveEntry.data.title : "";
const contentHtml =
	typeof liveEntry.data.content_html === "string"
		? liveEntry.data.content_html
		: "";
---

<Base title={title} bodyClass="single single-project">
	<section id="primary" class="col-12 px-4">
		<main id="content">
			<article class="project type-project status-publish">
				<header class="page-header">
					<h1 class="entry-title">{title}</h1>
				</header>
				<div class="entry-content">
					<div class="row">
						<div class="col-lg-9">
							<HtmlContent html={contentHtml} />
						</div>
					</div>
				</div>
			</article>
		</main>
	</section>
</Base>
