---
import RichContent from "../components/RichContent.astro";
import Base from "../layouts/Base.astro";
import { getPageByPath, getPageBySlug } from "../lib/seed";
import { getEmDashEditAttrs, joinPath } from "../lib/site";

const slugParts = Astro.params.slug?.split("/").filter(Boolean) ?? [];
const path = joinPath(slugParts);

const page =
	getPageByPath(path) ?? (slugParts.length === 1 ? getPageBySlug(path) : null);

if (!page) {
	return Astro.redirect("/404");
}

const useFullWidthTemplate =
	page.data.template === "templates/_full_width.php" &&
	page.data.path !== "faq";
---

<Base title={page.data.title}>
	{
		useFullWidthTemplate ? (
			<section id="primary" class="col-12 px-4">
				<main id="content">
					<article {...getEmDashEditAttrs("pages", page.slug, page.status)}>
						<header class="page-header">
							<h1
								class="entry-title"
								{...getEmDashEditAttrs(
									"pages",
									page.slug,
									page.status,
									"title",
								)}
							>
								{page.data.title}
							</h1>
						</header>
						<div
							class="entry-content"
							{...getEmDashEditAttrs(
								"pages",
								page.slug,
								page.status,
								"content_html",
							)}
						>
							<RichContent value={page.data.content_html} />
						</div>
					</article>
				</main>
			</section>
		) : (
			<div class="container-fluid">
				<section id="primary" class="p-4">
					<div id="content" role="main">
						<article {...getEmDashEditAttrs("pages", page.slug, page.status)}>
							<header class="page-header">
								<h1
									class="entry-title"
									{...getEmDashEditAttrs(
										"pages",
										page.slug,
										page.status,
										"title",
									)}
								>
									{page.data.title}
								</h1>
							</header>
							<div
								class="entry-content"
								{...getEmDashEditAttrs(
									"pages",
									page.slug,
									page.status,
									"content_html",
								)}
							>
								<RichContent value={page.data.content_html} />
							</div>
						</article>
					</div>
				</section>
			</div>
		)
	}
</Base>
