---
import HtmlContent from "../../components/HtmlContent.astro";
import ThemeSidebar from "../../components/ThemeSidebar.astro";
import Base from "../../layouts/Base.astro";
import { getEmDashEntry } from "emdash";
import { getPostBySlug } from "../../lib/seed";

const { slug = "" } = Astro.params;
const post = getPostBySlug(slug);

const livePost = post
	? null
	: await getEmDashEntry("posts", slug).then((result) => result.entry);

if (!post && !livePost) {
	return Astro.redirect("/404");
}

if (post) {
	return Astro.redirect(`/${post.data.path}/`);
}

const liveEntry = livePost!;
const title =
	typeof liveEntry.data.title === "string" ? liveEntry.data.title : "";
const contentHtml =
	typeof liveEntry.data.content_html === "string"
		? liveEntry.data.content_html
		: "";
const publishedOn =
	typeof liveEntry.data.published_on === "string"
		? liveEntry.data.published_on
		: "";
---

<Base title={title} bodyClass="single single-post content-sidebar">
	<section id="primary" class="col-lg-8 px-4">
		<div id="content" role="main">
			<article class="post">
				<header class="page-header">
					<h1 class="entry-title">{title}</h1>
					<div class="entry-meta">
						{publishedOn ? new Date(publishedOn).toLocaleDateString() : ""}
					</div>
				</header>
				<div class="entry-content">
					<HtmlContent html={contentHtml} />
				</div>
			</article>
		</div>
	</section>
	<ThemeSidebar />
</Base>
