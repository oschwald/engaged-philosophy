---
import RichContent from "../../components/RichContent.astro";
import Base from "../../layouts/Base.astro";
import { getEntryTerms, getProjectBySlug } from "../../lib/seed";
import { getEmDashEditAttrs } from "../../lib/site";

const { slug } = Astro.params;
const project = getProjectBySlug(slug ?? "");

if (!project) {
	return Astro.redirect("/404");
}

const schools = getEntryTerms(project, "schools");
const professors = getEntryTerms(project, "professors");
const courses = getEntryTerms(project, "courses");
const semesters = getEntryTerms(project, "semesters");
const topics = getEntryTerms(project, "topic");
---

<Base
	title={project.data.title}
	bodyClass={`wp-singular project-template-default single single-project${project.data.id ? ` postid-${project.data.id}` : ""} wp-theme-engaged-philosophy-20 content-sidebar`}
>
	<section id="primary" class="col-12 px-4">
		<main id="content">
			<article
				class="project type-project status-publish"
				{...getEmDashEditAttrs("projects", project.slug, project.status)}
			>
				<header class="page-header">
					<h1
						class="entry-title"
						{...getEmDashEditAttrs(
							"projects",
							project.slug,
							project.status,
							"title",
						)}
					>
						{project.data.title}
					</h1>
				</header>

				<div
					class="entry-content"
					{...getEmDashEditAttrs(
						"projects",
						project.slug,
						project.status,
						"content_html",
					)}
				>
					<div class="row">
						<div class="col-lg-9">
							<RichContent value={project.data.content_html} />
						</div>

						<div class="col-lg-3">
							<div class="well bg-light p-3 border rounded">
								<dl class="mb-0">
									{
										schools.length > 0 && (
											<>
												<dt>College</dt>
												<dd>
													{schools
														.map((term) => (
															<a href={`/schools/${term.slug}/`}>
																{term.label}
															</a>
														))
														.reduce((prev, curr) => [prev, ", ", curr])}
												</dd>
											</>
										)
									}
									{
										professors.length > 0 && (
											<>
												<dt>Professor</dt>
												<dd>
													{professors
														.map((term) => (
															<a href={`/professors/${term.slug}/`}>
																{term.label}
															</a>
														))
														.reduce((prev, curr) => [prev, ", ", curr])}
												</dd>
											</>
										)
									}
									{
										courses.length > 0 && (
											<>
												<dt>Course</dt>
												<dd>
													{courses
														.map((term) => (
															<a href={`/courses/${term.slug}/`}>
																{term.label}
															</a>
														))
														.reduce((prev, curr) => [prev, ", ", curr])}
												</dd>
											</>
										)
									}
									{
										semesters.length > 0 && (
											<>
												<dt>Semester</dt>
												<dd>
													{semesters
														.map((term) => (
															<a href={`/semesters/${term.slug}/`}>
																{term.label}
															</a>
														))
														.reduce((prev, curr) => [prev, ", ", curr])}
												</dd>
											</>
										)
									}
									{
										topics.length > 0 && (
											<>
												<dt>Topics</dt>
												<dd>
													{topics
														.map((term) => (
															<a href={`/topic/${term.slug}/`}>{term.label}</a>
														))
														.reduce((prev, curr) => [prev, ", ", curr])}
												</dd>
											</>
										)
									}
								</dl>
							</div>
						</div>
					</div>
				</div>
			</article>
		</main>
	</section>
</Base>
