---
import Base from "../layouts/Base.astro";
import RichContent from "../components/RichContent.astro";
import { getPageByPath, getPageBySlug } from "../lib/seed";
import {
	getEditModeEntryBySlug,
	getEmDashEditEntryAttrs,
	getEntryContent,
	getEntryContentField,
} from "../lib/site";

const page = await getEditModeEntryBySlug(
	"pages",
	"blog",
	getPageBySlug("blog") ?? getPageByPath("blog"),
);
---

<Base
	title={page?.data.title || "Blog"}
	bodyClass="page page-template page-template-default"
>
	<div class="container-fluid">
		<section id="primary" class="p-4">
			<div id="content" role="main">
				<article {...page ? getEmDashEditEntryAttrs("pages", page) : {}}>
					<header class="page-header">
						<h1
							class="entry-title"
							{...page ? getEmDashEditEntryAttrs("pages", page, "title") : {}}
						>
							{page?.data.title || "Blog"}
						</h1>
					</header>
					<div
						class="entry-content"
						{...page
							? getEmDashEditEntryAttrs(
									"pages",
									page,
									getEntryContentField(page.data),
								)
							: {}}
					>
						<RichContent
							value={page ? getEntryContent(page.data) : undefined}
						/>
					</div>
				</article>
			</div>
		</section>
	</div>
</Base>
