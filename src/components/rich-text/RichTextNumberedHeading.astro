---
import { PortableText } from "emdash/ui";
import type { RichTextNumberedHeadingNode } from "../../lib/rich-text-types";

interface Props {
	node: RichTextNumberedHeadingNode;
}

const { node } = Astro.props;
const level = Math.min(Math.max(node.level || 4, 1), 6);
const block = {
	...node.block,
	style: `h${level}`,
};
---

<ol start={node.index} class="legacy-numbered-heading">
	<li>
		<PortableText value={[block]} />
	</li>
</ol>
