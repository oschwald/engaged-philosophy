---
import { PTImage as EmDashPortableTextImage } from "emdash/ui";

import { getAssetSrc, isWordPressUploadUrl } from "../../lib/site";
import type {
	RichTextAssetRef,
	RichTextImageNode,
	RichTextRenderableImageNode,
} from "../../lib/rich-text-types";

interface Props {
	node: RichTextRenderableImageNode;
}

type StandardImageNode = RichTextImageNode & {
	_type: "image";
	_key: string;
	asset: RichTextAssetRef & {
		_ref: string;
	};
};

const { node } = Astro.props;
const getPublicMediaUrl = Astro.locals.emdash?.getPublicMediaUrl;

const isLegacyNode = node._type === "legacyImage";
const src = getAssetSrc(node.asset, node.url, getPublicMediaUrl);
const href = node.href ? getAssetSrc(null, node.href, getPublicMediaUrl) : "";
const hasLegacyFeatures = Boolean(
	node.align ||
	node.href ||
	isLegacyNode ||
	isWordPressUploadUrl(node.asset?.url ?? node.url),
);

const alignmentClass =
	node.align === "left"
		? "alignleft"
		: node.align === "right"
			? "alignright"
			: node.align === "center"
				? "aligncenter"
				: "";
const standardImageNode: StandardImageNode | null =
	node._type === "image" && node.asset?._ref
		? {
				_type: "image",
				_key: node._key,
				asset: {
					_ref: node.asset._ref,
					...(node.asset.url ? { url: node.asset.url } : {}),
					...(node.asset.provider ? { provider: node.asset.provider } : {}),
					...(node.asset.meta ? { meta: node.asset.meta } : {}),
				},
				...(node.alt ? { alt: node.alt } : {}),
				...(node.caption ? { caption: node.caption } : {}),
				...(typeof node.width === "number" ? { width: node.width } : {}),
				...(typeof node.height === "number" ? { height: node.height } : {}),
				...(typeof node.displayWidth === "number"
					? { displayWidth: node.displayWidth }
					: {}),
				...(typeof node.displayHeight === "number"
					? { displayHeight: node.displayHeight }
					: {}),
			}
		: null;
---

{
	hasLegacyFeatures ? (
		node?.caption ? (
			<figure class:list={["emdash-image", alignmentClass]}>
				{href ? (
					<a href={href}>
						<img
							src={src}
							alt={node?.alt || ""}
							width={node?.displayWidth || node?.width}
							height={node?.displayHeight || node?.height}
							loading="lazy"
							decoding="async"
							style="max-width: 100%; height: auto;"
						/>
					</a>
				) : (
					<img
						src={src}
						alt={node?.alt || ""}
						width={node?.displayWidth || node?.width}
						height={node?.displayHeight || node?.height}
						loading="lazy"
						decoding="async"
						style="max-width: 100%; height: auto;"
					/>
				)}
				<figcaption>{node.caption}</figcaption>
			</figure>
		) : href ? (
			<a href={href} class={alignmentClass || undefined}>
				<img
					src={src}
					alt={node?.alt || ""}
					width={node?.displayWidth || node?.width}
					height={node?.displayHeight || node?.height}
					loading="lazy"
					decoding="async"
					style="max-width: 100%; height: auto;"
				/>
			</a>
		) : (
			<img
				class={alignmentClass || undefined}
				src={src}
				alt={node?.alt || ""}
				width={node?.displayWidth || node?.width}
				height={node?.displayHeight || node?.height}
				loading="lazy"
				decoding="async"
				style="max-width: 100%; height: auto;"
			/>
		)
	) : (
		standardImageNode && <EmDashPortableTextImage node={standardImageNode} />
	)
}
