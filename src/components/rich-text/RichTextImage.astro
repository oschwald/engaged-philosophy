---
import { PTImage as EmDashPortableTextImage } from "emdash/ui";

import {
	getMediaUrlPrefix,
	isWordPressUploadUrl,
	rewriteWordPressUploadUrl,
} from "../../lib/site";

interface Props {
	node: {
		_type: "image" | "legacyImage";
		_key: string;
		asset?: {
			_ref?: string;
			url?: string;
			provider?: string;
			meta?: Record<string, unknown>;
		};
		url?: string;
		alt?: string;
		caption?: string;
		href?: string;
		align?: "left" | "right" | "center";
		width?: number;
		height?: number;
		displayWidth?: number;
		displayHeight?: number;
	};
}

type StandardImageNode = {
	_type: "image";
	_key: string;
	asset: {
		_ref: string;
		url?: string;
		provider?: string;
		meta?: Record<string, unknown>;
	};
	alt?: string;
	caption?: string;
	width?: number;
	height?: number;
	displayWidth?: number;
	displayHeight?: number;
};

const { node } = Astro.props;
const assetUrl = node.asset?.url ?? node.url ?? "";
const isLegacyNode = node._type === "legacyImage";
const isLegacyUpload = isWordPressUploadUrl(assetUrl);
const mediaUrlPrefix = getMediaUrlPrefix();
const src = isLegacyUpload
	? rewriteWordPressUploadUrl(assetUrl, mediaUrlPrefix)
	: assetUrl;
const href = isWordPressUploadUrl(node.href)
	? rewriteWordPressUploadUrl(node.href, mediaUrlPrefix)
	: node.href;
const alignmentClass =
	node.align === "left"
		? "alignleft"
		: node.align === "right"
			? "alignright"
			: node.align === "center"
				? "aligncenter"
				: "";
const standardImageNode: StandardImageNode | null =
	node._type === "image" && node.asset?._ref
		? {
				_type: "image",
				_key: node._key,
				asset: {
					_ref: node.asset._ref,
					...(node.asset.url ? { url: node.asset.url } : {}),
					...(node.asset.provider ? { provider: node.asset.provider } : {}),
					...(node.asset.meta ? { meta: node.asset.meta } : {}),
				},
				...(node.alt ? { alt: node.alt } : {}),
				...(node.caption ? { caption: node.caption } : {}),
				...(typeof node.width === "number" ? { width: node.width } : {}),
				...(typeof node.height === "number" ? { height: node.height } : {}),
				...(typeof node.displayWidth === "number"
					? { displayWidth: node.displayWidth }
					: {}),
				...(typeof node.displayHeight === "number"
					? { displayHeight: node.displayHeight }
					: {}),
			}
		: null;
---

{
	isLegacyNode || isLegacyUpload ? (
		node?.caption ? (
			<figure class:list={["emdash-image", alignmentClass]}>
				{href ? (
					<a href={href}>
						<img
							src={src}
							alt={node?.alt || ""}
							width={node?.displayWidth || node?.width}
							height={node?.displayHeight || node?.height}
							loading="lazy"
							decoding="async"
							style="max-width: 100%; height: auto;"
						/>
					</a>
				) : (
					<img
						src={src}
						alt={node?.alt || ""}
						width={node?.displayWidth || node?.width}
						height={node?.displayHeight || node?.height}
						loading="lazy"
						decoding="async"
						style="max-width: 100%; height: auto;"
					/>
				)}
				<figcaption>{node.caption}</figcaption>
			</figure>
		) : href ? (
			<a href={href} class={alignmentClass || undefined}>
				<img
					src={src}
					alt={node?.alt || ""}
					width={node?.displayWidth || node?.width}
					height={node?.displayHeight || node?.height}
					loading="lazy"
					decoding="async"
					style="max-width: 100%; height: auto;"
				/>
			</a>
		) : (
			<img
				class={alignmentClass || undefined}
				src={src}
				alt={node?.alt || ""}
				width={node?.displayWidth || node?.width}
				height={node?.displayHeight || node?.height}
				loading="lazy"
				decoding="async"
				style="max-width: 100%; height: auto;"
			/>
		)
	) : (
		standardImageNode && <EmDashPortableTextImage node={standardImageNode} />
	)
}
