---
import { PTImage as EmDashPortableTextImage } from "emdash/ui";

import {
	getMediaUrlPrefix,
	isWordPressUploadUrl,
	rewriteWordPressUploadUrl,
} from "../../lib/site";

interface Props {
	node: {
		_type: "image";
		_key: string;
		asset: {
			_ref: string;
			url?: string;
			provider?: string;
			meta?: Record<string, unknown>;
		};
		alt?: string;
		caption?: string;
		href?: string;
		align?: "left" | "right" | "center";
		width?: number;
		height?: number;
		displayWidth?: number;
		displayHeight?: number;
	};
}

const { node } = Astro.props;
const assetUrl = node.asset.url ?? "";
const isLegacyUpload = isWordPressUploadUrl(assetUrl);
const mediaUrlPrefix = getMediaUrlPrefix();
const src = isLegacyUpload
	? rewriteWordPressUploadUrl(assetUrl, mediaUrlPrefix)
	: "";
const href = isWordPressUploadUrl(node.href)
	? rewriteWordPressUploadUrl(node.href, mediaUrlPrefix)
	: node.href;
const alignmentClass =
	node.align === "left"
		? "alignleft"
		: node.align === "right"
			? "alignright"
			: node.align === "center"
				? "aligncenter"
				: "";
---

{
	isLegacyUpload ? (
		node?.caption ? (
			<figure class:list={["emdash-image", alignmentClass]}>
				{href ? (
					<a href={href}>
						<img
							src={src}
							alt={node?.alt || ""}
							width={node?.displayWidth || node?.width}
							height={node?.displayHeight || node?.height}
							loading="lazy"
							decoding="async"
							style="max-width: 100%; height: auto;"
						/>
					</a>
				) : (
					<img
						src={src}
						alt={node?.alt || ""}
						width={node?.displayWidth || node?.width}
						height={node?.displayHeight || node?.height}
						loading="lazy"
						decoding="async"
						style="max-width: 100%; height: auto;"
					/>
				)}
				<figcaption>{node.caption}</figcaption>
			</figure>
		) : href ? (
			<a href={href} class={alignmentClass || undefined}>
				<img
					src={src}
					alt={node?.alt || ""}
					width={node?.displayWidth || node?.width}
					height={node?.displayHeight || node?.height}
					loading="lazy"
					decoding="async"
					style="max-width: 100%; height: auto;"
				/>
			</a>
		) : (
			<img
				class={alignmentClass || undefined}
				src={src}
				alt={node?.alt || ""}
				width={node?.displayWidth || node?.width}
				height={node?.displayHeight || node?.height}
				loading="lazy"
				decoding="async"
				style="max-width: 100%; height: auto;"
			/>
		)
	) : (
		<EmDashPortableTextImage node={node} />
	)
}
