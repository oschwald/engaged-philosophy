---
import {
	getMediaUrlPrefix,
	isWordPressUploadUrl,
	rewriteWordPressSiteUrl,
	rewriteWordPressUploadUrl,
} from "../../lib/site";

interface Props {
	node: {
		markDef: {
			_type: "link";
			_key: string;
			href: string;
			blank?: boolean;
		};
	};
}

const { node } = Astro.props;
const href = isWordPressUploadUrl(node?.markDef?.href)
	? rewriteWordPressUploadUrl(node.markDef.href, getMediaUrlPrefix())
	: rewriteWordPressSiteUrl(node?.markDef?.href);
const blank = node?.markDef?.blank;
---

<a
	href={href}
	target={blank ? "_blank" : undefined}
	rel={blank ? "noopener noreferrer" : undefined}
>
	<slot />
</a>
