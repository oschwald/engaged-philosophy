---
import type { RichTextEmbedNode } from "../../lib/rich-text-types";
import { safeUrlForHref, safeUrlForIframeSrc } from "../../lib/url-safety";

interface Props {
	node: RichTextEmbedNode;
}

const { node } = Astro.props;
const title = node.title || "Embedded media";
const embedUrl = safeUrlForIframeSrc(node.embedUrl);
const linkUrl = safeUrlForHref(node.url);
---

{
	embedUrl ? (
		<figure
			class:list={[
				"legacy-embed",
				node.provider && `legacy-embed--${node.provider}`,
			]}
		>
			<div class="legacy-embed__frame">
				<iframe
					src={embedUrl}
					title={title}
					loading="lazy"
					allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
					allowfullscreen
					referrerpolicy="strict-origin-when-cross-origin"
				/>
			</div>
		</figure>
	) : (
		linkUrl && (
			<p>
				<a href={linkUrl}>{title}</a>
			</p>
		)
	)
}

<style>
	.legacy-embed {
		margin: 1.5rem 0;
	}

	.legacy-embed__frame {
		position: relative;
		width: 100%;
		aspect-ratio: 16 / 9;
		background: #000;
	}

	.legacy-embed__frame iframe {
		position: absolute;
		inset: 0;
		display: block;
		width: 100%;
		height: 100%;
		border: 0;
	}
</style>
