---
import { Gallery as EmDashGallery } from "emdash/ui";

import {
	getMediaUrlPrefix,
	isWordPressUploadUrl,
	rewriteWordPressUploadUrl,
} from "../../lib/site";

interface Props {
	node: {
		_type: "gallery";
		_key: string;
		align?: "left" | "right" | "center";
		caption?: string;
		layout?: "figure" | "shortcode";
		images: Array<{
			_type: "image";
			_key: string;
			asset: {
				_ref: string;
				url?: string;
			};
			alt?: string;
			caption?: string;
			width?: number;
			height?: number;
		}>;
		columns?: number;
	};
}

const { node } = Astro.props;
const images = node.images;
const mediaUrlPrefix = getMediaUrlPrefix();
const isLegacyGallery =
	images.length > 0 &&
	images.every((image) => isWordPressUploadUrl(image.asset.url));
const usesLeadLayout =
	node.layout === "shortcode" && node.columns === 3 && images.length === 4;
const alignmentClass =
	node.align === "left"
		? "alignleft"
		: node.align === "right"
			? "alignright"
			: node.align === "center"
				? "aligncenter"
				: "";
---

{
	isLegacyGallery ? (
		node.layout === "shortcode" ? (
			<div
				class:list={[
					"legacy-gallery",
					"legacy-gallery-shortcode",
					node.columns ? `legacy-gallery-columns-${node.columns}` : undefined,
					usesLeadLayout && "legacy-gallery-shortcode--lead",
					alignmentClass,
				]}
			>
				{images.map((image, index) => {
					const src = rewriteWordPressUploadUrl(
						image.asset?.url,
						mediaUrlPrefix,
					);
					const size = usesLeadLayout
						? index === 0
							? { width: 936, height: 936 }
							: { width: 309, height: 309 }
						: undefined;
					return (
						<a
							class:list={[
								"gallery-item",
								usesLeadLayout && index === 0 && "gallery-item--lead",
							]}
							href={src}
						>
							<img
								src={src}
								alt={image.alt || image.caption || ""}
								width={size?.width}
								height={size?.height}
								loading="lazy"
								decoding="async"
							/>
						</a>
					);
				})}
			</div>
		) : node.caption ? (
			<figure class:list={["legacy-gallery", alignmentClass]}>
				<ul
					class:list={[
						"blocks-gallery-grid",
						node.columns ? `columns-${node.columns}` : undefined,
					]}
				>
					{images.map((image) => {
						const src = rewriteWordPressUploadUrl(
							image.asset?.url,
							mediaUrlPrefix,
						);
						return (
							<li class="blocks-gallery-item">
								<figure>
									<a href={src}>
										<img
											src={src}
											alt={image.alt || image.caption || ""}
											width={image.width}
											height={image.height}
											loading="lazy"
											decoding="async"
										/>
									</a>
									{image.caption && (
										<figcaption class="blocks-gallery-item__caption">
											{image.caption}
										</figcaption>
									)}
								</figure>
							</li>
						);
					})}
				</ul>
				<figcaption class="blocks-gallery-caption">{node.caption}</figcaption>
			</figure>
		) : (
			<ul
				class:list={[
					"legacy-gallery",
					"blocks-gallery-grid",
					node.columns ? `columns-${node.columns}` : undefined,
					alignmentClass,
				]}
			>
				{images.map((image) => {
					const src = rewriteWordPressUploadUrl(
						image.asset?.url,
						mediaUrlPrefix,
					);
					return (
						<li class="blocks-gallery-item">
							<figure>
								<a href={src}>
									<img
										src={src}
										alt={image.alt || image.caption || ""}
										width={image.width}
										height={image.height}
										loading="lazy"
										decoding="async"
									/>
								</a>
								{image.caption && (
									<figcaption class="blocks-gallery-item__caption">
										{image.caption}
									</figcaption>
								)}
							</figure>
						</li>
					);
				})}
			</ul>
		)
	) : (
		<EmDashGallery node={node} />
	)
}
