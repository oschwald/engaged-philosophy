---
import { PortableText } from "emdash/ui";

import RichTextEmbed from "./rich-text/RichTextEmbed.astro";
import RichTextGallery from "./rich-text/RichTextGallery.astro";
import RichTextPageList from "./rich-text/RichTextPageList.astro";
import RichTextVideo from "./rich-text/RichTextVideo.astro";
import { isPortableTextValue } from "../lib/rich-text";
import type { RichTextValue } from "../lib/rich-text-types";

interface Props {
	value?: RichTextValue | null;
	class?: string;
}

const { value, class: className = "" } = Astro.props;
---

{
	isPortableTextValue(value) && (
		<div class:list={["legacy-content", className]}>
			<PortableText
				value={value}
				components={{
					type: {
						legacyEmbed: RichTextEmbed,
						gallery: RichTextGallery,
						legacyPageList: RichTextPageList,
						legacyVideo: RichTextVideo,
					},
				}}
			/>
		</div>
	)
}
