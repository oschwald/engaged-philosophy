---
import { getMediaUrlPrefix } from "../lib/site";

interface Props {
	html?: string | null;
	class?: string;
}

const { html, class: className = "" } = Astro.props;
const mediaUrlPrefix = getMediaUrlPrefix();
const blockTagPattern =
	/<\/?(?:address|article|aside|blockquote|details|div|dl|fieldset|figcaption|figure|footer|form|h[1-6]|header|hr|main|nav|ol|p|pre|section|table|thead|tbody|tr|td|th|ul|li)\b/gi;

function applyAutoParagraphs(value: string) {
	const normalized = value.replace(/\r\n?/g, "\n").trim();
	if (!normalized || /<p[\s>]/i.test(normalized)) return normalized;

	const separated = normalized.replace(
		blockTagPattern,
		(match) => `\n${match}\n`,
	);
	const chunks = separated
		.split(/\n{2,}/)
		.map((chunk) => chunk.trim())
		.filter(Boolean);

	return chunks
		.map((chunk) =>
			/^<\/?(?:address|article|aside|blockquote|details|div|dl|fieldset|figcaption|figure|footer|form|h[1-6]|header|hr|main|nav|ol|p|pre|section|table|thead|tbody|tr|td|th|ul|li)\b/i.test(
				chunk,
			)
				? chunk
				: `<p>${chunk.replace(/\n/g, "<br />\n")}</p>`,
		)
		.join("\n\n");
}

const normalizedHtml = (html ?? "")
	.replaceAll(/<!--[\s\S]*?-->/g, "")
	.replaceAll(/\[embed\]([^\[]+)\[\/embed\]/g, '<p><a href="$1">$1</a></p>')
	.replaceAll(/\[gallery[^\]]*\]/g, "")
	.replaceAll(
		/(src|href)=["']\/wp-content\/uploads\//g,
		`$1="${mediaUrlPrefix}/wp-content/uploads/`,
	)
	.replaceAll(
		/(srcset)=["']\/wp-content\/uploads\//g,
		`$1="${mediaUrlPrefix}/wp-content/uploads/`,
	)
	.replaceAll(
		/https?:\/\/www\.engagedphilosophy\.com\/wp-content\/uploads\//g,
		`${mediaUrlPrefix}/wp-content/uploads/`,
	)
	.replaceAll(
		/https?:\/\/engagedphilosophy\.com\/wp-content\/uploads\//g,
		`${mediaUrlPrefix}/wp-content/uploads/`,
	)
	.replaceAll(
		/https?:\/\/www\.engagedphilosophy\.com\/(?!wp-content\/uploads\/)/g,
		"/",
	)
	.replaceAll(
		/https?:\/\/engagedphilosophy\.com\/(?!wp-content\/uploads\/)/g,
		"/",
	);

const renderedHtml = applyAutoParagraphs(normalizedHtml);
---

<div class:list={["legacy-content", className]} set:html={renderedHtml} />
