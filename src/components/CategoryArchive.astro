---
import EntrySummary from "./content/EntrySummary.astro";
import Pagination from "./content/Pagination.astro";
import ThemeSidebar from "./ThemeSidebar.astro";
import { formatPathDate } from "../lib/path-utils";
import {
	getEntryContent,
	getEntryExcerpt,
	getExcerptText,
} from "../lib/rich-text";
import type { ContentEntry, PostData } from "../lib/types";

interface Props {
	slug: string;
	label: string;
	posts: ContentEntry<PostData>[];
	hasMore: boolean;
	page: number;
}

const { slug, label, posts, hasMore, page } = Astro.props;

function pageHref(pageNumber: number) {
	return pageNumber === 1
		? `/category/${slug}/`
		: `/category/${slug}/page/${pageNumber}/`;
}
---

<section id="primary" class="col-lg-8 p-4">
	<div id="content" role="main">
		<header class="page-header mb-4 pb-3 border-bottom">
			<h1 class="page-title h2 mb-0">
				Category Archives: <span>{label}</span>
			</h1>
		</header>

		{
			posts.length > 0 ? (
				posts.map((post) => (
					<EntrySummary
						articleClass="mb-5 pb-4 border-bottom post"
						title={post.data.title ?? ""}
						titleHref={`/${post.data.path}/`}
						meta={formatPathDate(post.data.path)}
						continueHref={`/${post.data.path}/`}
						excerpt={getExcerptText(
							getEntryExcerpt(post.data),
							getEntryContent(post.data),
						)}
					/>
				))
			) : (
				<article class="post no-results not-found">
					<header class="page-header">
						<h1 class="entry-title">Nothing Found</h1>
					</header>
					<div class="entry-content">
						<p>No posts were found for this category.</p>
					</div>
				</article>
			)
		}

		<Pagination
			currentPage={page}
			hasMore={hasMore}
			pageHref={pageHref}
			windowed
			nextLinkClass="next"
		/>
	</div>
</section>

<ThemeSidebar />
