{
	"name": "engaged-philosophy",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"description": "Engaged Philosophy migrated to Astro + EmDash on Cloudflare Workers",
	"scripts": {
		"generate:seed": "node scripts/generate-seed.mjs",
		"migrate:media": "node scripts/migrate-media-to-r2.mjs",
		"migrate:importer-schema": "node scripts/migrate-importer-schema.mjs",
		"migrate:portable-text": "node scripts/migrate-portable-text.mjs",
		"sync:seed-d1": "node scripts/sync-seed-to-d1.mjs",
		"audit:migration": "node scripts/audit-migration.mjs",
		"parity:audit": "node scripts/parity-audit.mjs",
		"dev": "astro dev",
		"build": "node scripts/assert-no-emdash-seed.mjs && astro build",
		"ci": "npm run lint && npm test && npm run typecheck && npm run build",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint:eslint": "eslint eslint.config.js \"scripts/**/*.mjs\" \"src/**/*.{js,ts,astro}\"",
		"lint": "npm run format:check && npm run lint:eslint",
		"lint:fix": "prettier --write . && npm run lint:eslint -- --fix",
		"test": "npm run test:portable-text && npm run test:functional",
		"test:functional": "node scripts/test-rendered-smoke.mjs",
		"test:smoke": "node scripts/test-rendered-smoke.mjs",
		"test:portable-text": "node scripts/test-portable-text.mjs",
		"preview": "astro preview",
		"deploy": "npm run build && wrangler deploy",
		"typecheck": "astro check"
	},
	"dependencies": {
		"@astrojs/cloudflare": "^13.5.4",
		"@astrojs/react": "^5.0.5",
		"@emdash-cms/cloudflare": "^0.15.0",
		"astro": "^6.3.7",
		"bootstrap": "^5.3.3",
		"emdash": "^0.15.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"sass": "^1.89.0",
		"turndown": "^7.2.4",
		"turndown-plugin-gfm": "^1.0.2"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.4",
		"@cloudflare/workers-types": "^4.20250525.0",
		"@typescript-eslint/eslint-plugin": "^8.60.0",
		"@typescript-eslint/parser": "^8.60.0",
		"astro-eslint-parser": "^1.4.0",
		"cheerio": "^1.2.0",
		"eslint": "^10.4.0",
		"eslint-plugin-astro": "^1.7.0",
		"pixelmatch": "^7.2.0",
		"playwright": "^1.60.0",
		"pngjs": "^7.0.0",
		"prettier": "^3.8.3",
		"prettier-plugin-astro": "^0.14.1",
		"typescript": "^5.8.3",
		"vite": "^7.3.3",
		"wrangler": "^4.17.0"
	}
}
