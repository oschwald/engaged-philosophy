{
	"name": "engaged-philosophy",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"description": "Engaged Philosophy migrated to Astro + EmDash on Cloudflare Workers",
	"scripts": {
		"generate:seed": "node scripts/migration/generate-seed.mjs",
		"migrate:media": "node scripts/migration/migrate-media-to-r2.mjs",
		"migrate:importer-schema": "node scripts/migration/migrate-importer-schema.mjs",
		"migrate:portable-text": "node scripts/migration/migrate-portable-text.mjs",
		"migrate:derived-path-fields": "node scripts/migration/hide-derived-path-fields.mjs",
		"sync:seed-d1": "node scripts/migration/sync-seed-to-d1.mjs",
		"audit:migration": "node scripts/migration/audit-migration.mjs",
		"audit:legacy-blocks": "node scripts/migration/audit-legacy-blocks.mjs",
		"audit:legacy-media": "node scripts/migration/audit-legacy-media.mjs",
		"audit:launch-data": "node scripts/migration/audit-launch-data.mjs",
		"audit:wordpress-transforms": "node scripts/migration/audit-wordpress-transforms.mjs",
		"parity:audit": "node scripts/migration/parity-audit.mjs",
		"dev": "astro dev",
		"build": "node scripts/assert-no-emdash-seed.mjs && astro build",
		"ci": "npm run lint && npm test && npm run typecheck && npm run build && npm run test:worker-bundle && npm run test:worker-runtime",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint:eslint": "eslint eslint.config.js \"scripts/**/*.mjs\" \"src/**/*.{js,ts,astro}\"",
		"lint": "npm run format:check && npm run lint:eslint",
		"lint:fix": "prettier --write . && npm run lint:eslint -- --fix",
		"test": "npm run test:portable-text && npm run test:wordpress-media && npm run test:legacy-media-audit && npm run test:launch-data-audit && npm run test:content-paths && npm run test:plugin-config && npm run test:audit-log-plugin && npm run test:anonymous-cache && npm run test:admin-observability && npm run test:cloudflare-access-auth-config && npm run test:cloudflare-access-invite && npm run test:functional",
		"test:admin-observability": "node --experimental-strip-types scripts/test-admin-observability.ts",
		"test:anonymous-cache": "node --experimental-strip-types scripts/test-anonymous-cache.ts",
		"test:cloudflare-access-auth-config": "node scripts/test-cloudflare-access-auth-config.mjs",
		"test:cloudflare-access-invite": "node --experimental-strip-types scripts/test-cloudflare-access-invite.ts",
		"test:functional": "node scripts/test-rendered-smoke.mjs",
		"test:content-paths": "node --experimental-strip-types scripts/test-content-paths.ts",
		"test:plugin-config": "node --experimental-strip-types scripts/test-plugin-config.ts",
		"test:audit-log-plugin": "node --experimental-strip-types scripts/test-audit-log-plugin.ts",
		"test:legacy-media-audit": "node scripts/migration/test-legacy-media-audit.mjs",
		"test:launch-data-audit": "node scripts/migration/test-launch-data-audit.mjs",
		"test:smoke": "node scripts/test-rendered-smoke.mjs",
		"test:portable-text": "node scripts/migration/test-portable-text.mjs",
		"test:wordpress-media": "node scripts/migration/test-wordpress-media.mjs",
		"test:worker-bundle": "node scripts/test-worker-bundle.mjs",
		"test:worker-runtime": "node scripts/test-worker-runtime.mjs",
		"preview": "astro preview",
		"deploy": "npm run build && wrangler deploy",
		"typecheck": "astro check"
	},
	"dependencies": {
		"@astrojs/cloudflare": "^13.6.1",
		"@astrojs/react": "^5.0.7",
		"@emdash-cms/cloudflare": "^0.17.0",
		"@emdash-cms/plugin-audit-log": "^0.2.0",
		"@emdash-cms/plugin-embeds": "^0.1.19",
		"astro": "^6.4.4",
		"bootstrap": "^5.3.3",
		"emdash": "^0.17.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"sass": "^1.89.0"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.4",
		"@cloudflare/workers-types": "^4.20260603.1",
		"@typescript-eslint/eslint-plugin": "^8.60.0",
		"@typescript-eslint/parser": "^8.60.0",
		"astro-eslint-parser": "^1.4.0",
		"cheerio": "^1.2.0",
		"eslint": "^10.4.0",
		"eslint-plugin-astro": "^1.7.0",
		"pixelmatch": "^7.2.0",
		"playwright": "^1.60.0",
		"pngjs": "^7.0.0",
		"prettier": "^3.8.3",
		"prettier-plugin-astro": "^0.14.1",
		"turndown": "^7.2.4",
		"turndown-plugin-gfm": "^1.0.2",
		"typescript": "^6.0.3",
		"vite": "^7.3.3",
		"wrangler": "^4.97.0"
	},
	"overrides": {
		"@astro-community/astro-embed-integration": {
			"astro-auto-import": "^0.5.1"
		},
		"yaml-language-server": {
			"yaml": "^2.8.3"
		}
	}
}
